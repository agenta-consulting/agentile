{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "ruby \"${CLAUDE_PLUGIN_ROOT}/hooks/format-on-edit.rb\"",
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "ruby \"${CLAUDE_PLUGIN_ROOT}/hooks/test-gate.rb\"",
            "timeout": 600
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "ruby \"${CLAUDE_PLUGIN_ROOT}/hooks/test-gate.rb\"",
            "timeout": 600
          }
        ]
      }
    ]
  }
}
